{
  "name": "new-datadome-deobfuscator",
  "version": "2.0.0",
  "description": "Babel AST-based deobfuscator for DataDome's WAFs (interstitial and captcha). Up to date and maintained for the latest versions. Clean files, extract dynamic challenges, pull out the embedded WASM payload.",
  "main": "lib/index.js",
  "bin": {
    "datadome-deobfuscate": "bin/cli.js"
  },
  "files": [
    "lib",
    "bin",
    "transformers",
    "main.js",
    "README.md",
    "LEARN.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "deobfuscate": "node bin/cli.js",
    "deobfuscate:captcha": "node bin/cli.js input/captcha.js output/captcha/",
    "deobfuscate:interstitial": "node bin/cli.js input/interstitial.js output/interstitial/"
  },
  "keywords": [
    "datadome",
    "deobfuscator",
    "captcha",
    "interstitial",
    "ast",
    "babel",
    "reverse-engineering",
    "antibot"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glizzykingdreko/new-datadome-deobfuscator"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/helpers": "^7.29.2",
    "@babel/parser": "^7.29.2",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0"
  }
}
